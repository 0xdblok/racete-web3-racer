# Racete Game Server
# Copy to .env and customize before running in production.

# Server port (default: 2567)
GAME_SERVER_PORT=2567

# CORS origin — the URL of your Vercel-deployed frontend
# Default for local dev: http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Shared secret for signing multiplayer reward payloads
# Must match the value set in Vercel environment variables
# Generate with: openssl rand -hex 32
MULTIPLAYER_REWARD_SECRET=change-me-long-random-secret

# Token Stake Rooms V1 foundation (disabled/test mode only)
# Used later for server-only token-room lifecycle/finalize signing.
# No deposits, token transfers, or private signer keys are configured in Phase A.
TOKEN_ROOM_SECRET=change-me-before-token-room-server-use
RACETE_TEST_TOKEN_MINT=26vpJsWJswDbztCoZBEskkqjMKeFn9ym7s72Hn3spump
RACETE_TOKEN_MINT=TO_BE_PROVIDED_FINAL_PUMPFUN_MINT
TOKEN_WEEKLY_REWARD_WALLET=4oCUAXbyLfSzd6YifcL1QkXNqepm2cZpwxm3pqGNx6Lw
TOKEN_TREASURY_WALLET=ne8CVnmNJKuSegSLJ7PtA1zPqEKdynXSzivj4kKVXVG
TOKEN_STAKE_ROOMS_ENABLED=false
TOKEN_STAKE_ROOMS_TEST_MODE=true
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
